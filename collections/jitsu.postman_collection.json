            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Write-Key", "value": "{{writeKey}}" }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"track\",\n  \"event\": \"OrderCompleted\",\n  \"userId\": \"user-123\"\n}",
